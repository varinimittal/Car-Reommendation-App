{
  "openapi": "3.0.1",
  "info": {
    "title": "CarRecommendationApi",
    "version": "1.0"
  },
  "paths": {
    "/api/Recommendation": {
      "post": {
        "tags": [
          "Recommendation"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendationRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendationRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CarRecommendation"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CarRecommendation"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CarRecommendation"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CarRecommendation": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "mileage": {
            "type": "number",
            "format": "double"
          },
          "safetyRating": {
            "type": "integer",
            "format": "int32"
          },
          "recommendationReason": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RecommendationRequest": {
        "type": "object",
        "properties": {
          "budget": {
            "type": "number",
            "format": "double"
          },
          "fuelType": {
            "type": "string",
            "nullable": true
          },
          "bodyType": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}